-- // APLICAÇÃO INSTANTÂNEA E DIRETA
local function EnforceWeaponAttributes(item)
    if not item:IsA("Tool") or not TargetWeapons[item.Name] then return end
    
    local def = WeaponDefaults[item.Name]
    if not def then return end
    
    local targetSpread, targetSpeed, targetAuto
    
    if item.Name == "M4A1" then
        if _G.M4A1_Enabled then targetSpread = 0; targetSpeed = (_G.M4A1_Speed == "Fast") and 0.02 or 0.05; targetAuto = true
        else targetSpread = def.SpreadRadius; targetSpeed = def.FireRate; targetAuto = def.AutoFire end
        
    elseif item.Name == "AK-47" then
        if _G.AK47_Enabled then targetSpread = 0; targetSpeed = (_G.AK47_Speed == "Fast") and 0.025 or 0.06; targetAuto = true
        else targetSpread = def.SpreadRadius; targetSpeed = def.FireRate; targetAuto = def.AutoFire end
        
    elseif item.Name == "MP5" then
        if _G.MP5_Enabled then targetSpread = 0; targetSpeed = (_G.MP5_Speed == "Fast") and 0.06 or 0.07; targetAuto = true
        else targetSpread = def.SpreadRadius; targetSpeed = def.FireRate; targetAuto = def.AutoFire end
        
    elseif item.Name == "Remington 870" then
        -- Quando ativado, vira laser perfeito (0). Desativado, mantém precisão padrão de 0.06
        if _G.Remington_Enabled then targetSpread = 0; targetSpeed = 0.25; targetAuto = true
        else targetSpread = def.SpreadRadius; targetSpeed = def.FireRate; targetAuto = def.AutoFire end
        
    elseif item.Name == "M9" then
        if _G.M9_Enabled then targetSpread = 0; targetSpeed = (_G.M9_Speed == "Fast") and 0.07 or 0.10; targetAuto = true
        else targetSpread = def.SpreadRadius; targetSpeed = def.FireRate; targetAuto = def.AutoFire end
        
    else
        -- Garante que armas não-modificáveis mantenham seus valores padrões sem quebrar
        targetSpread = def.SpreadRadius; targetSpeed = def.FireRate; targetAuto = def.AutoFire
    end
    
    local gunStates = item:FindFirstChild("GunStates")
    if gunStates and gunStates:IsA("ModuleScript") then
        pcall(function()
            local module = require(gunStates)
            if type(module) == "table" then
                module.Spread = targetSpread
                module.SpreadRadius = targetSpread
                module.FireRate = targetSpeed
                module.AutoFire = targetAuto
            end
        end)
    end
    
    item:SetAttribute("SpreadRadius", targetSpread)
    item:SetAttribute("FireRate", targetSpeed)
    item:SetAttribute("AutoFire", targetAuto)
end

local function ModifyWeapon(item)
    if not item:IsA("Tool") or not TargetWeapons[item.Name] then return end
    EnforceWeaponAttributes(item)
end

local function RefreshWeapons()
    local bp, ch = localPlayer:FindFirstChild("Backpack"), localPlayer.Character
    if bp then for _, item in ipairs(bp:GetChildren()) do ModifyWeapon(item) end end
    if ch then for _, item in ipairs(ch:GetChildren()) do ModifyWeapon(item) end end
end

local function ForceReequip(weaponName)
    local character = localPlayer.Character
    if character then
        local tool = character:FindFirstChild(weaponName)
        if tool and tool:IsA("Tool") then
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            if humanoid then
                EnforceWeaponAttributes(tool)
                tool.Parent = localPlayer:FindFirstChild("Backpack")
                task_wait() -- Otimizado: Espera de apenas 1 frame físico para reequipamento instantâneo
                if tool.Parent then
                    humanoid:EquipTool(tool)
                end
            end
        end
    end
end

task_spawn(function()
    while task_wait(0.5) do
        RefreshWeapons()
    end
end)

