-- // SISTEMA OTIMIZADO DE PROCESSAMENTO HITBOX/ESP (Com Cache Amigo Ativo)
local function IsFriend(player)
    if FriendCache[player] ~= nil then return FriendCache[player] end
    local s, r = pcall(function() return localPlayer:IsFriendsWith(player.UserId) end)
    FriendCache[player] = s and r or false
    return FriendCache[player]
end

task_spawn(function()
    while task_wait(0.25) do
        for _, player in ipairs(Players:GetPlayers()) do
            if player == localPlayer then continue end
            local char = player.Character
            if not char then continue end
            
            local isF = IsFriend(player)
            
            if _G.HitboxEnabled then
                if _G.IgnoreTeam and player.Team == localPlayer.Team then
                    if OriginalData[player] then
                        for part, data in pairs(OriginalData[player]) do
                            if part and part.Parent then part.Size = data.Size; part.Transparency = data.Transparency; part.CanCollide = true; part.Massless = false end
                        end
                        OriginalData[player] = nil
                    end
                else
                    local targetPart = char:FindFirstChild(_G.HitboxTarget) or char:FindFirstChild("Head")
                    if targetPart and targetPart:IsA("BasePart") then
                        if not OriginalData[player] then OriginalData[player] = {} end
                        if not OriginalData[player][targetPart] then OriginalData[player][targetPart] = {Size = targetPart.Size, Transparency = targetPart.Transparency} end
                        
                        local tSize = Vector3.new(_G.HitboxSize, _G.HitboxSize, _G.HitboxSize)
                        if targetPart.Size ~= tSize or targetPart.Transparency ~= _G.HitboxTransparency then
                            targetPart.Size = tSize; targetPart.Transparency = _G.HitboxTransparency; targetPart.CanCollide = false; targetPart.Massless = true
                        end
                    end
                end
            elseif OriginalData[player] then
                for part, data in pairs(OriginalData[player]) do
                    if part and part.Parent then part.Size = data.Size; part.Transparency = data.Transparency; part.CanCollide = true; part.Massless = false end
                end
                OriginalData[player] = nil
            end

            local h = char:FindFirstChild("ESPHighlight")
            local s = char:FindFirstChild("HitboxBox")
            local head = char:FindFirstChild("Head")
            
            if isF and head and not head:FindFirstChild("FriendLabel") then
                local lg = Instance_new("BillboardGui", head); lg.Name = "FriendLabel"; lg.Size = UDim2_new(0, 100, 0, 40); lg.StudsOffset = Vector3.new(0, 2.5, 0); lg.AlwaysOnTop = true
                local txt = Instance_new("TextLabel", lg); txt.Size = UDim2_new(1, 0, 1, 0); txt.BackgroundTransparency = 1; txt.Text = "Amizade"; txt.TextColor3 = Color3_fromRGB(0, 255, 0); txt.TextStrokeTransparency = 0; txt.Font = Enum.Font.GothamBold; txt.TextSize = 14
            end

            if _G.ESPEnabled then
                if not h then h = Instance_new("Highlight", char); h.Name = "ESPHighlight"; h.FillTransparency = 1; h.OutlineTransparency = 0; h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop end
                h.OutlineColor = isF and Color3_fromRGB(0, 255, 0) or (player.TeamColor and player.TeamColor.Color or Color3_fromRGB(255, 40, 40))
                
                if not s then
                    local targetPart = char:FindFirstChild(_G.HitboxTarget) or head
                    if targetPart then s = Instance_new("SelectionBox", char); s.Name = "HitboxBox"; s.Adornee = targetPart; s.LineThickness = 0.05; s.Transparency = 0.3; s.SurfaceTransparency = 0.8 end
                end
                if s then s.Color3 = h.OutlineColor end
            else
                if h then h:Destroy() end
                if s then s:Destroy() end
            end
        end
    end
end)

