-- ==========================================================
-- SCRIPT DE ORGANIZAÇÃO DE INVENTÁRIO 
-- ==========================================================
if game.PlaceId == 155615604 or game.PlaceId == 135564683255158 then
    task_spawn(function()
        while not Players.LocalPlayer do task_wait() end
        local isOrganizing = false; local PriorityOrder = {"Remington 870"} 

        local function OrganizeInventory()
            if isOrganizing then return end
            if not _G.Remington_Enabled then return end
            
            local backpack = localPlayer:FindFirstChild("Backpack"); local character = localPlayer.Character
            if not backpack or not character then return end
            
            isOrganizing = true; local itemsFound = {}
            for _, name in ipairs(PriorityOrder) do
                local tool = backpack:FindFirstChild(name) or character:FindFirstChild(name)
                if tool and not tool:GetAttribute("AlreadyOrganized") then 
                    itemsFound[name] = tool
                    tool:SetAttribute("AlreadyOrganized", true) 
                end
            end
            
            for _, name in ipairs(PriorityOrder) do local tool = itemsFound[name]; if tool and tool.Parent == backpack then tool.Parent = nil end end
            for _, name in ipairs(PriorityOrder) do local tool = itemsFound[name]; if tool and tool.Parent ~= character then tool.Parent = backpack end end
            task_wait(0.2); isOrganizing = false
        end

        local function Initialize(backpack)
            if backpack:GetAttribute("IsMonitoredOrg") then return end
            backpack:SetAttribute("IsMonitoredOrg", true)
            
            backpack.ChildAdded:Connect(function(item) 
                if item:IsA("Tool") and item.Name == "Remington 870" and not item:GetAttribute("AlreadyOrganized") then 
                    task_wait(0.3)
                    OrganizeInventory() 
                end 
            end)
        end
        
        localPlayer.CharacterAdded:Connect(function() 
            local backpack = localPlayer:WaitForChild("Backpack", 3)
            if backpack then Initialize(backpack) end 
        end)
        
        local currentBackpack = localPlayer:FindFirstChild("Backpack")
        if currentBackpack then Initialize(currentBackpack) end
    end)
end
